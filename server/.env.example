# Copy to .env and adjust if needed. All values have sensible defaults.

# Server port
PORT=5000

# JWT signing secret (change for any real deployment)
JWT_SECRET=dev-secret-change-me

# MongoDB connection string.
# Leave EMPTY to auto-start an in-memory MongoDB (zero install, great for demos).
# Set to a real URI to use local MongoDB or MongoDB Atlas, e.g.:
#   mongodb://127.0.0.1:27017/virtual-wardrobe
#   mongodb+srv://user:pass@cluster.mongodb.net/virtual-wardrobe
MONGO_URI=

# Where in-memory MongoDB persists its data between restarts (so demo data survives).
MEMORY_DB_PATH=./.memory-db
